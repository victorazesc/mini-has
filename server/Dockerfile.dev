FROM node:22-bookworm-slim

WORKDIR /app

RUN apt-get update \
  && apt-get install -y --no-install-recommends python3 make g++ iputils-ping net-tools ca-certificates \
  && rm -rf /var/lib/apt/lists/*

COPY package*.json ./
RUN npm install

EXPOSE 8000
CMD ["sh", "-c", "npm install && npm run start:dev"]
